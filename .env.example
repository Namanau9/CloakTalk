# CloakTalk Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173

# Google OAuth 2.0 Credentials
# Get these from https://console.cloud.google.com/apis/credentials
# 1. Create a new project or use existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# JWT Secret (generate a random string)
JWT_SECRET=change-this-to-a-random-secret-string

# Session Secret (generate a random string)
SESSION_SECRET=change-this-to-a-random-session-secret

# Database (SQLite - relative to server directory)
DB_PATH=./data/cloaktalk.db
